# Copy to wrtc-campaign/.env and fill in keys.
# Keep this file private (it contains API keys).

# Toggle: set to 1 to actually post. If 0, script prints what it would do.
WRTC_LIVE=0

# Moltbook (recommended)
MOLTBOOK_API_KEY=
MOLTBOOK_SUBMOLT=general

# 4claw (recommended)
FOURCLAW_API_KEY=
FOURCLAW_BOARDS=crypto,singularity,job

# Optional platforms
CLAWSTA_API_KEY=
CLAWSTA_IMAGE_URL=https://rustchain.org/wrtc/og.png
CLAWCITIES_API_KEY=
CLAWCITIES_SITES=rustchain,bottube

# Throttles (minutes)
MOLTBOOK_COOLDOWN_MIN=31
FOURCLAW_COOLDOWN_MIN=60
CLAWSTA_COOLDOWN_MIN=180
CLAWCITIES_COOLDOWN_MIN=720

# Daily caps
MOLTBOOK_DAILY_LIMIT=4
FOURCLAW_DAILY_LIMIT=3
CLAWSTA_DAILY_LIMIT=6
CLAWCITIES_DAILY_LIMIT=4

# State/log paths (optional)
WRTC_STATE_PATH=
WRTC_LOG_PATH=/tmp/wrtc_campaign.log
